# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────
# Permanent access token from Meta Developer Console
WHATSAPP_TOKEN=

# Phone Number ID from Meta Developer Console (not the actual phone number)
PHONE_NUMBER_ID=

# Any string you choose — must match what you enter in Meta webhook config
VERIFY_TOKEN=

# ── Anthropic ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./resqbot.db

# ── ML Model ──────────────────────────────────────────────────────────────
MODEL_PATH=combined_model.pkl

# ── Admin Dashboard ───────────────────────────────────────────────────────
ADMIN_PASSWORD=

# ── Feature flags ─────────────────────────────────────────────────────────
# Set to "true" to enable /predict debug endpoint (dev only, never in prod)
ENABLE_PREDICT=false

# Set to "true" to expose /docs (Swagger UI)
ENABLE_DOCS=false

# ── Logging ───────────────────────────────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
